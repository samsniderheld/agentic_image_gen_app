# Google AI API key (required for Gemini provider)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API key (optional, for OpenAI provider)
OPENAI_API_KEY=your_openai_api_key_here

# Pipeline selection (optional - overrides active_pipeline in pipeline.yaml)
# Options: default, quick, minimal, style_focused
PIPELINE=default
